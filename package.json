{
  "name": "jaccount-cli",
  "version": "0.1.0",
  "description": "Local-first Playwright CLI for SJTU jAccount task portal automation.",
  "type": "module",
  "bin": {
    "jaccount": "./dist/src/cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx \"tests/**/*.test.ts\"",
    "dev": "tsx src/cli.ts",
    "jaccount": "node dist/src/cli.js",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "files": [
    "dist/src",
    "config/entries.example.json",
    "config/entries.schema.json",
    "docs",
    "skills",
    "README.md",
    "PROJECT_PLAN.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ddddocr": "^1.0.0",
    "jsqr": "^1.4.0",
    "playwright": "^1.49.0",
    "pngjs": "^7.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
